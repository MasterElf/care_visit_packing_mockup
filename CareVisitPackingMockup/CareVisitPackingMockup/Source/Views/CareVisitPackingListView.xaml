<UserControl x:Class="CareVisitPackingMockup.CareVisitPackingListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CareVisitPackingMockup"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SectionHeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="DetailLabelTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,8,4" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="DetailValueTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Packing list"
                   Style="{StaticResource SectionHeaderTextBlockStyle}" />

        <ListView x:Name="PackingListItemsListView"
                  Grid.Row="1"
                  ItemsSource="{Binding PackingItems}"
                  SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Qty"
                                    Width="60"
                                    DisplayMemberBinding="{Binding DefaultQuantity}" />

                    <GridViewColumn Header="Item"
                                    Width="260"
                                    DisplayMemberBinding="{Binding MedicalItem.Name}" />

                    <GridViewColumn Header="Category"
                                    Width="160"
                                    DisplayMemberBinding="{Binding MedicalItem.Category}" />

                    <GridViewColumn Header="Mandatory"
                                    Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsMandatory}"
                                          IsHitTestVisible="False"
                                          Focusable="False"
                                          HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="12"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4"
                DataContext="{Binding SelectedItem, ElementName=PackingListItemsListView}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Selected item:"
                           Style="{StaticResource DetailLabelTextBlockStyle}" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding MedicalItem.Name, TargetNullValue='Select an item in the list above.'}"
                           Style="{StaticResource DetailValueTextBlockStyle}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Quantity:"
                           Style="{StaticResource DetailLabelTextBlockStyle}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding DefaultQuantity}"
                           Style="{StaticResource DetailValueTextBlockStyle}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Reason:"
                           Style="{StaticResource DetailLabelTextBlockStyle}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding Reason}"
                           Style="{StaticResource DetailValueTextBlockStyle}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Text="Description:"
                           Style="{StaticResource DetailLabelTextBlockStyle}" />
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Text="{Binding MedicalItem.Description}"
                           Style="{StaticResource DetailValueTextBlockStyle}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
