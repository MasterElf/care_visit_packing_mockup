<UserControl x:Class="CareVisitPackingMockup.AppointmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CareVisitPackingMockup"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=local:CalendarAppointmentModel}">

    <UserControl.Resources>
        <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="ValueTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SectionHeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,20,0,8" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Padding="24">
                <StackPanel>
                    <TextBox Text="{Binding Subject, TargetNullValue=No appointment selected, FallbackValue=No appointment selected}"
                              FontSize="26"
                              FontWeight="SemiBold"
                              TextWrapping="Wrap"
                              BorderThickness="0"
                              Background="Transparent"
                              Margin="0,0,0,18" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm}, FallbackValue=-}"
                                       Style="{StaticResource ValueTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="End" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm}, FallbackValue=-}"
                                       Style="{StaticResource ValueTextBlockStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Location" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding Location, TargetNullValue=-, FallbackValue=-}"
                               Style="{StaticResource ValueTextBlockStyle}" />

                    <TextBlock Text="Notes" Style="{StaticResource CaptionTextBlockStyle}" />
                    <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,10">
                        <TextBlock Text="{Binding Notes, TargetNullValue=-, FallbackValue=-}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Care types" Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <ItemsControl ItemsSource="{Binding CareTypes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CareTypeModel}">
                                <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                        BorderThickness="1"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="15"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />

                                        <TextBlock Text="{Binding HandbookReference, StringFormat={}Handbook reference: {0}}"
                                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Expander Header="Persisted care type IDs"
                              Margin="0,16,0,0">
                        <ItemsControl ItemsSource="{Binding CareTypeIds}"
                                      Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <TextBlock Text="{Binding Id, StringFormat={}Appointment ID: {0}}"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,20,0,0" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
