<Window x:Class="CareVisitPackingMockup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CareVisitPackingMockup"
        xmlns:ad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="1400">
    <Grid>
        <ad:DockingManager x:Name="DockManager">
            <ad:LayoutRoot>
                <ad:LayoutPanel Orientation="Vertical">

                    <ad:LayoutAnchorablePane DockHeight="250">
                        <ad:LayoutAnchorable Title="Navigation" ContentId="NavigationPanel" CanClose="False">
                            <local:SchedulePicker DataContext="{Binding AppointmentCollectionModel}" />
                        </ad:LayoutAnchorable>
                    </ad:LayoutAnchorablePane>

                    <ad:LayoutPanel Orientation="Horizontal">

                        <ad:LayoutAnchorablePane DockWidth="*">
                            <ad:LayoutAnchorable Title="Appointment" ContentId="AppointmentPanel" CanClose="False">
                                <!--<panels:OutputPanelView />-->
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>

                        <ad:LayoutAnchorablePane DockWidth="*">
                            <ad:LayoutAnchorable Title="PackingList" ContentId="PackingListPanel" CanClose="False">
                                <!--<panels:OutputPanelView />-->
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>

                    </ad:LayoutPanel>

                </ad:LayoutPanel>
            </ad:LayoutRoot>
        </ad:DockingManager>
    </Grid>
</Window>
